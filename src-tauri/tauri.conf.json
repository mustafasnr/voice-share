{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Voice Share",
  "version": "1.0.3",
  "identifier": "com.mssoftware.voice-share",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Voice Share",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
